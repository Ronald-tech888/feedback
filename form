<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>DIY Plumbing Feedback | 水管维修反馈表 - 中英双语</title>
    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0b3b5f, #1b7f8a);
            min-height: 100vh;
            padding: 40px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            max-width: 700px;
            width: 100%;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            padding: 40px 35px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: transform 0.3s ease;
        }

        .container:hover {
            transform: translateY(-5px);
        }

        .lang-switch {
            text-align: right;
            margin-bottom: 20px;
        }

        .lang-btn {
            background: rgba(255,255,255,0.2);
            border: 1px solid rgba(255,255,255,0.3);
            padding: 8px 18px;
            border-radius: 40px;
            color: white;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            transition: all 0.2s;
            margin-left: 10px;
        }

        .lang-btn.active {
            background: #ff6b35;
            border-color: #ff6b35;
        }

        .lang-btn:hover {
            background: rgba(255,107,53,0.7);
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        h1 {
            font-size: 2rem;
            font-weight: 600;
            color: white;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        h1 i {
            margin-right: 12px;
            font-size: 2rem;
            vertical-align: middle;
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.9rem;
            font-weight: 300;
        }

        .form-group {
            margin-bottom: 22px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: white;
            font-size: 0.9rem;
        }

        label i {
            margin-right: 8px;
            width: 20px;
            color: #ffd166;
        }

        input, select, textarea {
            width: 100%;
            padding: 14px 16px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.95rem;
            border: none;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.95);
            transition: all 0.2s ease;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            background: white;
            box-shadow: 0 0 0 3px rgba(255, 210, 90, 0.5);
            transform: scale(1.01);
        }

        .rating-container {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        .rating-container input {
            display: none;
        }

        .rating-container label {
            font-size: 30px;
            color: rgba(255, 255, 255, 0.5);
            cursor: pointer;
            transition: 0.2s;
            margin: 0;
        }

        .rating-container label:hover,
        .rating-container label:hover ~ label,
        .rating-container input:checked ~ label {
            color: #ffb703;
            text-shadow: 0 0 5px #ffb703;
        }

        .rating-text {
            margin-left: 12px;
            font-size: 0.85rem;
            color: white;
            background: rgba(0,0,0,0.3);
            padding: 4px 12px;
            border-radius: 40px;
            display: inline-block;
        }

        button {
            width: 100%;
            padding: 15px;
            background: #ff6b35;
            color: white;
            border: none;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            transition: all 0.25s ease;
            margin-top: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        button:hover {
            background: #ff8255;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
        }

        button:active {
            transform: translateY(1px);
        }

        .success-message {
            margin-top: 20px;
            padding: 14px;
            background: #2e7d64;
            border-radius: 60px;
            text-align: center;
            color: white;
            font-weight: 500;
            display: none;
            animation: fadeInUp 0.4s ease;
        }

        .error-message {
            margin-top: 20px;
            padding: 14px;
            background: #c23b22;
            border-radius: 60px;
            text-align: center;
            color: white;
            font-weight: 500;
            display: none;
            animation: fadeInUp 0.4s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 550px) {
            .container {
                padding: 30px 20px;
            }
            h1 {
                font-size: 1.4rem;
            }
            .rating-container label {
                font-size: 24px;
            }
        }

        .required-star {
            color: #ffb347;
            margin-left: 4px;
        }

        footer {
            text-align: center;
            margin-top: 25px;
            font-size: 0.7rem;
            color: rgba(255,255,240,0.6);
        }

        .hint {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.6);
            margin-top: 5px;
        }

        /* Loading spinner */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        button:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="lang-switch">
        <button class="lang-btn active" data-lang="en">English</button>
        <button class="lang-btn" data-lang="zh">中文</button>
    </div>

    <div class="header">
        <h1>
            <i class="fas fa-wrench"></i> 
            <span class="trans" data-en="DIY Plumbing Feedback" data-zh="DIY 水管维修反馈">DIY Plumbing Feedback</span>
        </h1>
        <p class="subtitle"><i class="fas fa-comment-dots"></i> 
            <span class="trans" data-en="Share your DIY experience, help us improve" data-zh="分享你的维修经验，帮我们做得更好">Share your DIY experience, help us improve</span>
        </p>
    </div>

    <!-- FormSubmit Integration -->
    <form action="https://formsubmit.co/purchasingpoweruser@gmail.com" method="POST" id="plumbingFeedbackForm">
        <!-- FormSubmit hidden configuration -->
        <input type="hidden" name="_subject" value="New DIY Plumbing Feedback Submission">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_template" value="table">
        <input type="hidden" name="_next" value="https://ronald-tech888.github.io/diy-plumbing-workshop/thanks.html">
        <input type="hidden" name="_cc" value="midasmines@gmail.com,desmondsia.everlifestyle@gmail.com">
        
        <!-- Additional hidden fields for tracking -->
        <input type="hidden" name="_blacklist" value="spam,sex,abuse">
        <input type="hidden" name="_version" value="v1.0">

        <div class="form-group">
            <label><i class="fas fa-user"></i> 
                <span class="trans" data-en="Your Name" data-zh="你的名字">Your Name</span>
                <span class="required-star">*</span>
            </label>
            <input type="text" id="name" name="name" data-en-placeholder="e.g. John Doe" data-zh-placeholder="例如: 张三" placeholder="e.g. John Doe" required>
        </div>

        <div class="form-group">
            <label><i class="fas fa-envelope"></i> 
                <span class="trans" data-en="Email Address" data-zh="电子邮箱">Email Address</span>
            </label>
            <input type="email" id="email" name="email" data-en-placeholder="your@email.com (for reply)" data-zh-placeholder="your@email.com (用于回复)" placeholder="your@email.com (for reply)">
        </div>

        <div class="form-group">
            <label><i class="fas fa-tools"></i> 
                <span class="trans" data-en="Project Type" data-zh="维修项目">Project Type</span>
            </label>
            <select id="projectType" name="project_type">
                <option value="Leaky Faucet" data-en="🚰 Leaky Faucet" data-zh="🚰 漏水龙头">🚰 Leaky Faucet</option>
                <option value="Clogged Drain" selected data-en="🚽 Clogged Drain" data-zh="🚽 堵塞下水道">🚽 Clogged Drain</option>
                <option value="Toilet Repair" data-en="🚽 Toilet Repair" data-zh="🚽 马桶维修">🚽 Toilet Repair</option>
                <option value="Pipe Installation" data-en="🔧 Pipe Installation" data-zh="🔧 水管安装">🔧 Pipe Installation</option>
                <option value="Water Heater" data-en="💧 Water Heater" data-zh="💧 热水器问题">💧 Water Heater</option>
            </select>
        </div>

        <div class="form-group">
            <label><i class="fas fa-star"></i> 
                <span class="trans" data-en="Overall Rating" data-zh="整体评分">Overall Rating</span>
            </label>
            <div class="rating-container">
                <input type="radio" name="rating" value="5" id="star5"><label for="star5">★</label>
                <input type="radio" name="rating" value="4" id="star4"><label for="star4">★</label>
                <input type="radio" name="rating" value="3" id="star3"><label for="star3">★</label>
                <input type="radio" name="rating" value="2" id="star2"><label for="star2">★</label>
                <input type="radio" name="rating" value="1" id="star1"><label for="star1">★</label>
                <span class="rating-text" id="ratingLabel">
                    <span class="trans" data-en="Click stars to rate" data-zh="点击星星评分">Click stars to rate</span>
                </span>
            </div>
        </div>

        <div class="form-group">
            <label><i class="fas fa-pen-fancy"></i> 
                <span class="trans" data-en="Your Feedback / Suggestions" data-zh="你的反馈/建议">Your Feedback / Suggestions</span>
                <span class="required-star">*</span>
            </label>
            <textarea id="feedbackText" name="feedback" rows="4" data-en-placeholder="Describe your experience, DIY process, or suggestions..." data-zh-placeholder="描述你遇到的问题、DIY过程或改进建议..." placeholder="Describe your experience, DIY process, or suggestions..." required></textarea>
        </div>

        <!-- Optional: Add a hidden honeypot field to prevent spam -->
        <input type="text" name="_honey" style="display:none">

        <button type="submit" id="submitBtn">
            <i class="fas fa-paper-plane"></i> 
            <span class="trans" data-en="Submit Feedback" data-zh="提交反馈">Submit Feedback</span>
        </button>
    </form>

    <div id="successMsg" class="success-message">
        <i class="fas fa-check-circle"></i> 
        <span class="trans" data-en="Thank you for your feedback! 🪠 Redirecting..." data-zh="感谢你的反馈！ 🪠 正在跳转...">Thank you for your feedback! 🪠 Redirecting...</span>
    </div>
    
    <div id="errorMsg" class="error-message">
        <i class="fas fa-exclamation-triangle"></i> 
        <span class="trans" data-en="Something went wrong. Please try again or contact support." data-zh="出错了，请重试或联系客服。">Something went wrong. Please try again or contact support.</span>
    </div>
    
    <footer>
        <i class="fas fa-shield-alt"></i> 
        <span class="trans" data-en="Your opinion helps more DIY enthusiasts" data-zh="你的意见能帮助更多DIY爱好者">Your opinion helps more DIY enthusiasts</span>
    </footer>
</div>

<script>
    // 双语评分文本
    const ratingTexts = {
        en: {
            1: '⭐ Very Poor, needs improvement',
            2: '⭐⭐ Not good',
            3: '⭐⭐⭐ Average',
            4: '⭐⭐⭐⭐ Pretty good',
            5: '⭐⭐⭐⭐⭐ Excellent!',
            default: 'Click stars to rate'
        },
        zh: {
            1: '⭐ 很差，需要大改进',
            2: '⭐⭐ 不太好',
            3: '⭐⭐⭐ 一般般',
            4: '⭐⭐⭐⭐ 还不错',
            5: '⭐⭐⭐⭐⭐ 太棒了！',
            default: '点击星星评分'
        }
    };

    let currentLang = 'en';

    const starRadios = document.querySelectorAll('input[name="rating"]');
    const ratingLabelSpan = document.getElementById('ratingLabel');

    function updateRatingText(value) {
        let text = '';
        if (value) {
            text = ratingTexts[currentLang][value] || ratingTexts[currentLang].default;
        } else {
            text = ratingTexts[currentLang].default;
        }
        ratingLabelSpan.innerHTML = text;
    }

    starRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            updateRatingText(parseInt(this.value));
        });
    });

    // 切换语言函数
    function switchLanguage(lang) {
        currentLang = lang;
        
        document.querySelectorAll('.trans').forEach(el => {
            if (lang === 'en' && el.getAttribute('data-en')) {
                el.textContent = el.getAttribute('data-en');
            } else if (lang === 'zh' && el.getAttribute('data-zh')) {
                el.textContent = el.getAttribute('data-zh');
            }
        });

        document.querySelectorAll('input[data-en-placeholder], textarea[data-en-placeholder]').forEach(el => {
            if (lang === 'en' && el.getAttribute('data-en-placeholder')) {
                el.placeholder = el.getAttribute('data-en-placeholder');
            } else if (lang === 'zh' && el.getAttribute('data-zh-placeholder')) {
                el.placeholder = el.getAttribute('data-zh-placeholder');
            }
        });

        document.querySelectorAll('#projectType option').forEach(opt => {
            if (lang === 'en' && opt.getAttribute('data-en')) {
                opt.textContent = opt.getAttribute('data-en');
            } else if (lang === 'zh' && opt.getAttribute('data-zh')) {
                opt.textContent = opt.getAttribute('data-zh');
            }
        });

        const selectedRating = document.querySelector('input[name="rating"]:checked');
        if (selectedRating) {
            updateRatingText(parseInt(selectedRating.value));
        } else {
            updateRatingText(null);
        }

        document.querySelectorAll('.lang-btn').forEach(btn => {
            if (btn.getAttribute('data-lang') === lang) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });
    }

    document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const lang = this.getAttribute('data-lang');
            switchLanguage(lang);
        });
    });

    // FormSubmit 提交处理 - 让表单正常提交，FormSubmit 会自动处理重定向
    const form = document.getElementById('plumbingFeedbackForm');
    const submitBtn = document.getElementById('submitBtn');
    const successDiv = document.getElementById('successMsg');
    const errorDiv = document.getElementById('errorMsg');
    let isSubmitting = false;

    // 获取双语验证消息
    function getValidationMessage(type) {
        const messages = {
            en: {
                nameRequired: '❌ Please enter your name',
                feedbackRequired: '❌ Please enter your feedback'
            },
            zh: {
                nameRequired: '❌ 请填写你的名字',
                feedbackRequired: '❌ 请填写反馈内容'
            }
        };
        return messages[currentLang][type];
    }

    // 前端验证 + 显示加载状态
    form.addEventListener('submit', async function(e) {
        const name = document.getElementById('name').value.trim();
        const feedback = document.getElementById('feedbackText').value.trim();
        
        if (name === '') {
            e.preventDefault();
            alert(getValidationMessage('nameRequired'));
            return false;
        }
        
        if (feedback === '') {
            e.preventDefault();
            alert(getValidationMessage('feedbackRequired'));
            return false;
        }
        
        // 显示加载状态
        if (!isSubmitting) {
            isSubmitting = true;
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loading"></span> <span class="trans" data-en="Sending..." data-zh="发送中...">Sending...</span>';
            submitBtn.disabled = true;
            
            // 更新双语文本
            if (currentLang === 'en') {
                submitBtn.querySelector('span').textContent = 'Sending...';
            } else {
                submitBtn.querySelector('span').textContent = '发送中...';
            }
            
            // 显示提交中提示（可选）
            successDiv.style.display = 'none';
            errorDiv.style.display = 'none';
            
            // 允许表单正常提交，FormSubmit 会自动处理
            // 注意：表单会正常提交并重定向到 _next URL
            return true;
        }
    });
    
    // 注意：由于 FormSubmit 会重定向到 thanks.html，
    // 成功消息会在 thanks 页面显示，而不是当前页面
    // 如果你想在当前页面显示成功消息而不跳转，可以使用 fetch API
    
    // 可选：如果你想在当前页面提交而不跳转，使用这个 AJAX 版本（注释掉上面的默认提交）
    // 取消注释下面的代码可以实现无刷新提交：
    
